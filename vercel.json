{
  "rewrites": [
    {
      "source": "/teamsoccer-assets/(.*)",
      "destination": "/teamsoccer-assets/$1"
    },
    {
      "source": "/favicon.png",
      "destination": "/favicon.png"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/placeholder.svg",
      "destination": "/placeholder.svg"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}